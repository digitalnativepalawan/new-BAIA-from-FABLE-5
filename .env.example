# Frontend env vars (Vite). Copy to .env and fill in for YOUR Supabase project.
# When Lovable connects a new Supabase, it sets these for you.
VITE_SUPABASE_PROJECT_ID="your-new-project-ref"
VITE_SUPABASE_URL="https://your-new-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-new-anon-key"

# Claim-based auth. Keep "false" until STAFF_JWT_SECRET is set and RLS is
# migrated. See docs/security/rls-migration.md
VITE_USE_STAFF_JWT="false"

# ─────────────────────────────────────────────────────────────────────────────
# Edge-function secrets (set in Supabase, NOT here — listed for reference):
#   INTERNAL_FN_SECRET   - guards admin-summary / guest-requests-api / telegram
#   STAFF_JWT_SECRET     - = your project's JWT secret (Settings -> API)
#   OPENROUTER_API_KEY   - AI functions (concierge-ai, ops-coordinator, ...)
#   LOVABLE_API_KEY      - Lovable AI function(s)
#   TELEGRAM_BOT_TOKEN   - send-telegram
#   SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are auto-injected by Supabase.
