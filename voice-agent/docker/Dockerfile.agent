# TALA agent worker + token server -- shared Python image, two entrypoints.
FROM python:3.11-slim

WORKDIR /app

COPY agent/requirements.txt ./agent/requirements.txt
RUN pip install --no-cache-dir -r agent/requirements.txt

COPY agent ./agent

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

# Default to the LiveKit worker; docker-compose overrides command= for the
# token-server container to run uvicorn instead.
CMD ["python", "-m", "agent.livekit_agent", "start"]
